{
  "manifest_version": 3,
  "name": "Pinboard",
  "description": "Drop shared design feedback pins on any webpage.",
  "version": "0.1.0",
  "action": {
    "default_title": "Pinboard"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "sidePanel", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ]
}
